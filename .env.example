# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# Whoop OAuth
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REFRESH_TOKEN=your_whoop_refresh_token

# Database
# Local dev: ../data/activities.db (outside the git repo — not committed, reused across sessions)
# Docker:    /app/data/activities.db (override with a volume mount at /data)
DATABASE_PATH=../data/activities.db

# Cron Schedule (5am daily - "0 5 * * *")
CRON_SCHEDULE=0 5 * * *

# App
NODE_ENV=production
